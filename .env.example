DATABASE_URL=sqlite:///app/data/your-analytics.db
HOST=0.0.0.0
PORT=3000
RUST_LOG=your_analytics=info

# Authentication
# Username for the admin account created on first startup (default: admin)
ADMIN_USERNAME=admin

# Password for the admin account created on first startup.
# If unset, a random password is generated and printed to the application log.
ADMIN_PASSWORD=changeme

# Secret key used to encrypt session cookies.
# Generate with: openssl rand -hex 64
# If unset, a random key is generated on every startup (users are logged out on restart).
SECRET_KEY=
